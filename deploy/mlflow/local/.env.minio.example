# ============================================
# MinIO 설정
# ============================================
MINIO_ROOT_USER=minio-user
MINIO_ROOT_PASSWORD=minio-password-change-me
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ============================================
# PostgreSQL 설정 (기존과 동일)
# ============================================
POSTGRES_USER=mlflow
POSTGRES_PASSWORD=mlflow_local_password
POSTGRES_DB=mlflow

# ============================================
# MLflow 메타데이터 (기존)
# ============================================
# MLFLOW_TRACKING_URI와 MLFLOW_BACKEND_STORE_URI는
# compose 파일에서 자동 설정됨
# Client에서는 MLFLOW_TRACKING_URI만 사용:
# export MLFLOW_TRACKING_URI=http://localhost:5000

# ============================================
# 주의: AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY,
# MLFLOW_S3_ENDPOINT_URL는 설정하지 마세요.
# MLflow 서버가 자동으로 사용합니다 (Proxy Mode).
# ============================================
