POSTGRES_USER=mlflow
POSTGRES_PASSWORD=mlflow_local_password
POSTGRES_DB=mlflow
MLFLOW_TRACKING_URI=http://localhost:5000

# smoke test Experiment/모드 태그 — 로컬과 GCS 모드가 같은 Experiment를
# 재사용하면 GCS 검증이 기존 로컬 artifact location을 물려받아 무효화되므로
# 반드시 분리한다.
MLFLOW_SMOKE_EXPERIMENT=smoke-test-local
MLFLOW_ARTIFACT_STORE_MODE=local

# GCS 검증 모드(compose.gcs.yaml)에서만 값을 채운다.
# 이때 위 두 값도 smoke-test-gcs / gcs 로 바꿔서 사용한다.
MLFLOW_ARTIFACT_DESTINATION=gs://your-bucket/mlflow-artifacts
GCS_KEY_FILE_HOST_PATH=./keys/service-account.json
