# ============================================================================
# Feast Feature Store 환경 변수 (.env)
# 이 파일을 복사해서 .env 로 만들고 실제 값을 입력하세요:
#   cp .env.example .env
# ============================================================================

# GCP 서비스 계정 키 JSON 파일 경로
GOOGLE_APPLICATION_CREDENTIALS=./keys/service-account.json

# BigQuery (Offline Store)
GCP_PROJECT_ID=project-id
BQ_DATASET=feast_offline_store
BQ_LOCATION=asia-northeast3

# GCS Staging (BigQuery materialize 임시 저장소)
GCS_STAGING_LOCATION=gs://feast-staging-autoresearch/

# Memorystore for Redis (Online Store)
# 인스턴스 생성 후 콘솔에서 IP 확인
REDIS_HOST=
REDIS_PORT=6379

# YouTube Data API v3 developer keys (쉼표 구분 복수; Key 무효화 대응)
YOUTUBE_API_KEYS=
# (폴백) 단수 Key — YOUTUBE_API_KEYS 가 우선.
YOUTUBE_API_KEY=

# GCS bucket name for the data lake (no gs:// prefix)
YOUTUBE_LAKE_BUCKET=

# Kaggle global parquet source for the backfill DAG (gs:// or local path)
YOUTUBE_BACKFILL_SOURCE=

# Cloud Run 프록시 URL (1차: 미설정=비활성. 2차 PR에서 주입)
YOUTUBE_PROXY_URL=
