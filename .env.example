# ============================================================================
# Feast Feature Store 환경 변수 (.env)
# 이 파일을 복사해서 .env 로 만들고 실제 값을 입력하세요:
#   cp .env.example .env
# ============================================================================

# GCP 서비스 계정 키 JSON 파일 경로
# GOOGLE_APPLICATION_CREDENTIALS=./keys/service-account.json

# BigQuery (Offline Store)
GCP_PROJECT_ID=your-gcp-project-id
BQ_DATASET=feast_offline_store
BQ_LOCATION=asia-northeast3

# GCS Registry (FeatureView 메타데이터 저장 위치, registry.db 파일 경로)
GCS_REGISTRY_PATH=gs://your-registry-bucket/registry.db

# GCS Staging (BigQuery materialize 임시 저장소)
GCS_STAGING_LOCATION=gs://your-staging-bucket/

# Memorystore for Redis (Online Store)
# 인스턴스 생성 후 콘솔에서 IP 확인
REDIS_HOST=localhost
REDIS_PORT=6379

# YouTube Data API v3 developer keys (쉼표 구분 복수; Key 무효화 대응)
YOUTUBE_API_KEYS=
# (폴백) 단수 Key — YOUTUBE_API_KEYS 가 우선.
YOUTUBE_API_KEY=

# GCS bucket name for the data lake (no gs:// prefix)
YOUTUBE_LAKE_BUCKET=

# Kaggle global parquet source for the public backfill command (gs:// or local path)
YOUTUBE_BACKFILL_SOURCE=

# Cloud Run 프록시 URL (1차: 미설정=비활성. 2차 PR에서 주입)
YOUTUBE_PROXY_URL=

# Action log public command defaults for local execution.
ACTION_LOG_VIRTUAL_USERS_PATH=
ACTION_LOG_OUTPUT_DIR=
ACTION_LOG_QUARANTINE_DIR=
ACTION_LOG_GENERATOR=rule_based
ACTION_LOG_CANDIDATES_PER_USER=24
ACTION_LOG_TARGET_CTR=0.02
ACTION_LOG_PERSONALIZED_RATIO=0.7
ACTION_LOG_POPULAR_RATIO=0.2
ACTION_LOG_EXPLORATION_RATIO=0.1
ACTION_LOG_MAX_CONCURRENCY=1
ACTION_LOG_CHUNK_SIZE=0
# 100 work 이하는 micro-work별 상세 timing, 초과 시 interval 집계 로그만 기록합니다.
# 숫자가 아니거나 허용 범위를 벗어난 telemetry 값은 아래 기본값으로 대체됩니다.
ACTION_LOG_TELEMETRY_DETAIL_MAX_WORK=100
# 대규모 실행 집계 주기(10~30초).
ACTION_LOG_TELEMETRY_INTERVAL_SEC=15
OPENROUTER_API_KEY=
OPENROUTER_TIMEOUT_SEC=60
OPENROUTER_MAX_RETRIES=2
# APITimeoutError는 중복 비용 위험을 제한하기 위해 별도 한도로 제한합니다.
OPENROUTER_TIMEOUT_MAX_RETRIES=1
OPENROUTER_RETRY_BACKOFF_BASE_SEC=1
OPENROUTER_RETRY_BACKOFF_MAX_SEC=30
# Optional provider routing. Empty values preserve OpenRouter defaults.
OPENROUTER_PROVIDER_SORT=
OPENROUTER_ALLOW_FALLBACKS=
OPENROUTER_REQUIRE_PARAMETERS=
