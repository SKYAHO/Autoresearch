# ============================================================================
# Feast Feature Store 환경 변수 (.env)
# 이 파일을 복사해서 .env 로 만들고 실제 값을 입력하세요:
#   cp .env.example .env
# ============================================================================

# GCP 서비스 계정 키 JSON 파일 경로
GOOGLE_APPLICATION_CREDENTIALS=./keys/service-account.json

# BigQuery (Offline Store)
GCP_PROJECT_ID=autoresearch-project-id
BQ_DATASET=dataset-bigquery
BQ_LOCATION=asia-northeast3

# GCS Staging (BigQuery materialize 임시 저장소)
GCS_STAGING_LOCATION=gs://feast-staging-gcs/

# Memorystore for Redis (Online Store)
# 인스턴스 생성 후 콘솔에서 IP 확인
REDIS_HOST=10.0.0.2
REDIS_PORT=6379
